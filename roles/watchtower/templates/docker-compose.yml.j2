# {{ ansible_managed }}
services:
  watchtower:
    image: containrrr/watchtower:latest
    container_name: watchtower
    restart: unless-stopped
    environment:
      WATCHTOWER_SCHEDULE: "{{ target_watchtower.schedule }}"
      WATCHTOWER_CLEANUP: "{{ target_watchtower.cleanup | lower }}"
      WATCHTOWER_INCLUDE_STOPPED: "{{ target_watchtower.include_stopped | lower }}"
      WATCHTOWER_INCLUDE_RESTARTING: "{{ target_watchtower.include_restarting | lower }}"
      WATCHTOWER_NOTIFICATIONS: "{{ 'shoutrrr' if target_watchtower.notifications else '' }}"
      WATCHTOWER_NOTIFICATION_URL: "{{ vault_watchtower_notification_url | default('') }}"
      WATCHTOWER_LABEL_ENABLE: "true"
      DOCKER_HOST: "tcp://docker-socket-proxy:2375"
      TZ: "{{ target_timezone }}"
    networks:
      - socket-network
    labels:
      - "com.centurylinklabs.watchtower.enable=true"
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:8080/v1/update"]
      interval: 60s
      timeout: 10s
      retries: 3
      start_period: 30s

networks:
  socket-network:
    external: true
